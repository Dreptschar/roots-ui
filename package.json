{
  "name": "roots-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:api": "openapi-generator-cli generate -i openapi.yaml -g typescript-fetch -o src/generated/openapi --additional-properties=supportsES6=true,typescriptThreePlus=true,enumPropertyNaming=original,stringEnums=true,useSingleRequestParameter=true,withSeparateModelsAndApi=true",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  }
}
